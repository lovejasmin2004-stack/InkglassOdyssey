{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "world_events",
  "title": "WorldEvents",
  "type": "object",
  "required": ["id", "world_id", "name", "trigger", "effects"],
  "additionalProperties": false,
  "properties": {
    "id":       { "type": "string" },
    "world_id": { "type": "string" },
    "name":     { "type": "string", "minLength": 1 },
    "trigger": {
      "type": "object",
      "required": ["category"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": ["new_region", "npc_interaction_start", "combat_start", "player_idle", "weather_change", "world_event"]
        },
        "region_id":   { "type": "string" },
        "conditions":  { "type": "object" }
      }
    },
    "effects": {
      "type": "object",
      "properties": {
        "environmental_effects": { "type": "array", "items": { "type": "string" } },
        "narrative_hint":        { "type": "string" },
        "faction_standing":      { "type": "object", "additionalProperties": { "type": "integer" } },
        "companion_reactions":   { "type": "array", "items": { "type": "string" } }
      }
    },
    "duration_turns": { "type": ["integer", "null"], "minimum": 1 },
    "description":    { "type": "string" }
  }
}
