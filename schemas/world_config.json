{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "world_config",
  "title": "WorldConfig",
  "type": "object",
  "required": [
    "world_id", "display_name", "content_rating", "rp_system_prompt_addendum",
    "traversal_config", "currency_id", "ability_score_map",
    "max_active_companions", "specialisation_paths", "rest_rules", "economy_config"
  ],
  "additionalProperties": false,
  "properties": {
    "world_id":                    { "type": "string", "minLength": 1 },
    "display_name":                { "type": "string", "minLength": 1 },
    "content_rating": {
      "type": "string",
      "enum": ["moderate", "mature"]
    },
    "rp_system_prompt_addendum":   { "type": "string" },
    "traversal_config": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "currency_id":                 { "type": "string", "minLength": 1 },
    "ability_score_map": {
      "type": "object",
      "required": ["strength", "dexterity", "constitution", "intelligence", "wisdom", "charisma"],
      "additionalProperties": false,
      "properties": {
        "strength":     { "type": "string", "minLength": 1 },
        "dexterity":    { "type": "string", "minLength": 1 },
        "constitution": { "type": "string", "minLength": 1 },
        "intelligence": { "type": "string", "minLength": 1 },
        "wisdom":       { "type": "string", "minLength": 1 },
        "charisma":     { "type": "string", "minLength": 1 }
      }
    },
    "equipment_slots": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "resource_model":              { "type": "object" },
    "time_of_day_cycle":           { "type": "object" },
    "max_active_companions": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "specialisation_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "world", "display_name", "path_archetype", "hit_die",
                     "saving_throw_proficiencies", "primary_ability_scores",
                     "available_skill_proficiencies", "description"],
        "additionalProperties": false,
        "properties": {
          "id":            { "type": "string", "minLength": 1 },
          "world":         { "type": "string", "minLength": 1 },
          "display_name":  { "type": "string", "minLength": 1 },
          "path_archetype": {
            "type": "string",
            "enum": ["scholar", "balanced", "martial", "tank"]
          },
          "hit_die": { "type": "integer", "enum": [6, 8, 10, 12] },
          "saving_throw_proficiencies": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["strength", "dexterity", "constitution", "intelligence", "wisdom", "charisma"]
            },
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true
          },
          "primary_ability_scores": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["strength", "dexterity", "constitution", "intelligence", "wisdom", "charisma"]
            },
            "minItems": 1,
            "maxItems": 2,
            "uniqueItems": true
          },
          "available_skill_proficiencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "description": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "rest_rules": {
      "type": "object",
      "required": ["short_rest_hp_percent", "short_rest_hit_dice_formula",
                   "long_rest_hp_percent", "long_rest_exhaustion_reduction"],
      "additionalProperties": false,
      "properties": {
        "short_rest_hp_percent":          { "type": "number", "minimum": 0, "maximum": 1 },
        "short_rest_hit_dice_formula":    { "type": "string" },
        "long_rest_hp_percent":           { "type": "number", "minimum": 0, "maximum": 1 },
        "long_rest_exhaustion_reduction": { "type": "integer", "minimum": 0 }
      }
    },
    "economy_config": {
      "type": "object",
      "required": ["sell_back_ratio"],
      "additionalProperties": true,
      "properties": {
        "earning_rates":         { "type": "object" },
        "price_ranges":          { "type": "object" },
        "sell_back_ratio":       { "type": "number", "minimum": 0, "maximum": 1 },
        "crafting_margin_target":{ "type": "number", "minimum": 0, "maximum": 1 },
        "transport_fare_ranges": { "type": "object" }
      }
    },
    "environmental_effects_registry": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
