{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faction",
  "title": "Faction",
  "type": "object",
  "required": ["id", "name", "allied_factions", "rival_factions", "reputation_thresholds", "description"],
  "additionalProperties": false,
  "properties": {
    "id":       { "type": "string", "minLength": 1 },
    "world_id": { "type": "string", "minLength": 1 },
    "name":     { "type": "string", "minLength": 1 },
    "allied_factions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "rival_factions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "reputation_thresholds": {
      "type": "object",
      "required": ["hostile", "unfriendly", "neutral", "friendly", "allied"],
      "additionalProperties": false,
      "properties": {
        "hostile":    { "type": "integer" },
        "unfriendly": { "type": "integer" },
        "neutral":    { "type": "integer" },
        "friendly":   { "type": "integer" },
        "allied":     { "type": "integer" }
      }
    },
    "description": { "type": "string" },
    "shop_price_modifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allied":     { "type": "number" },
        "friendly":   { "type": "number" },
        "neutral":    { "type": "number" },
        "unfriendly": { "type": "number" }
      }
    },
    "notable_npcs": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
