{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ability",
  "title": "Ability",
  "type": "object",
  "required": ["id", "world", "name", "description", "ability_score", "cost", "level_requirement", "tags"],
  "additionalProperties": false,
  "properties": {
    "id":              { "type": "string" },
    "world":           { "type": "string" },
    "name":            { "type": "string", "minLength": 1 },
    "description":     { "type": "string" },
    "ability_score":   { "type": "string" },
    "modifier_source": { "type": "string" },
    "damage_dice":     { "type": "string" },
    "damage_type":     { "type": "string" },
    "healing_dice":    { "type": "string" },
    "save_type":       { "type": "string" },
    "save_dc_source":  { "type": "string" },
    "applies_condition": {
      "type": "object",
      "required": ["condition_id", "duration"],
      "additionalProperties": false,
      "properties": {
        "condition_id": { "type": "string" },
        "duration":     { "type": "integer", "minimum": 1 }
      }
    },
    "cost": {
      "type": "object",
      "required": ["resource_type", "amount"],
      "additionalProperties": false,
      "properties": {
        "resource_type": { "type": "string" },
        "amount":        { "type": "integer", "minimum": 0 }
      }
    },
    "cooldown_turns":    { "type": "integer", "minimum": 1 },
    "level_requirement": { "type": "integer", "minimum": 1, "maximum": 20 },
    "tags":              { "type": "array", "items": { "type": "string" } }
  }
}
