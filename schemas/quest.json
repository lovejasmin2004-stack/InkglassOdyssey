{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quest",
  "title": "Quest",
  "type": "object",
  "required": ["id", "world_id", "name", "description", "objectives", "rewards"],
  "additionalProperties": false,
  "properties": {
    "id":          { "type": "string" },
    "world_id":    { "type": "string" },
    "name":        { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "giver_npc_id": { "type": "string" },
    "region_id":   { "type": "string" },
    "level_requirement": { "type": "integer", "minimum": 1, "maximum": 20 },
    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "quests_completed":    { "type": "array", "items": { "type": "string" } },
        "faction_standing":    { "type": "object", "additionalProperties": { "type": "integer" } },
        "flags":               { "type": "array", "items": { "type": "string" } }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string" },
          "description": { "type": "string" },
          "optional":    { "type": "boolean", "default": false }
        }
      }
    },
    "rewards": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency":           { "type": "integer", "minimum": 0 },
        "items":              { "type": "array", "items": { "type": "string" } },
        "faction_standing":   { "type": "object", "additionalProperties": { "type": "integer" } },
        "experience_flag":    { "type": "boolean" },
        "unlocks_recipe":     { "type": "string" }
      }
    },
    "flags_on_complete": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
